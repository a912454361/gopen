/* 首页样式 */

.home-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #0f0f1a 0%, #1a1a2e 50%, #252540 100%);
}

.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
  margin-top: 80rpx;
}

.logo-container {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #ffd700, #c9a96e);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 0 40rpx rgba(255, 215, 0, 0.5);
}

.logo-icon {
  font-size: 80rpx;
}

.game-title {
  font-size: 56rpx;
  font-weight: bold;
  color: #ffd700;
  margin-bottom: 12rpx;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3);
}

.game-subtitle {
  font-size: 28rpx;
  color: #aaaaaa;
}

.info-card {
  width: 100%;
  margin-bottom: 32rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  color: #aaaaaa;
  font-size: 28rpx;
}

.info-value {
  color: #ffffff;
  font-size: 28rpx;
}

.save-card {
  width: 100%;
  margin-bottom: 32rpx;
}

.save-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.save-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.stat-mini {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 215, 0, 0.1);
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
}

.stat-name {
  font-size: 22rpx;
  color: #aaaaaa;
}

.stat-val {
  font-size: 28rpx;
  color: #ffd700;
  font-weight: bold;
}

.save-info {
  display: flex;
  gap: 32rpx;
}

.button-section {
  width: 100%;
  margin-top: 20rpx;
}

.button-section button {
  width: 100%;
  margin-bottom: 20rpx;
}

.secondary-buttons {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-top: 24rpx;
}

.btn-text {
  background: transparent;
  color: #aaaaaa;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
}

.btn-text::after {
  display: none;
}

.description-section {
  margin-top: 48rpx;
  padding: 32rpx;
  text-align: center;
}
