/* 横屏游戏主页面样式 */

/* 横屏容器 */
.landscape-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: row;
  background: #0f0f1a;
}

/* 左侧游戏画布区域 */
.game-area {
  flex: 1;
  position: relative;
  background: radial-gradient(ellipse at center, #1a1a2e 0%, #0f0f1a 100%);
}

.game-canvas {
  width: 100%;
  height: 100%;
}

/* 画布覆盖UI */
.canvas-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  pointer-events: none;
}

.canvas-overlay > * {
  pointer-events: auto;
}

/* 画质选择栏 */
.quality-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10px);
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.quality-label {
  font-size: 24rpx;
  color: #888;
  margin-right: 10rpx;
}

.quality-btn {
  font-size: 22rpx;
  color: #666;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.quality-btn.active {
  color: #ffd700;
  background: rgba(255, 215, 0, 0.2);
}

/* 粒子数显示 */
.particle-display {
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10px);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.particle-display text {
  font-size: 22rpx;
  color: #888;
}

/* 右侧信息面板 */
.info-panel {
  width: 320rpx;
  background: linear-gradient(180deg, rgba(26, 26, 46, 0.95) 0%, rgba(15, 15, 26, 0.98) 100%);
  border-left: 1px solid rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  gap: 16rpx;
}

/* 用户卡片 */
.user-card {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.user-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.avatar-container {
  position: relative;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2px solid #ffd700;
}

.vip-badge {
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 16rpx;
  background: linear-gradient(135deg, #ffd700, #ff8c00);
  color: #000;
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  font-weight: bold;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
  display: block;
}

.level-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 6rpx;
}

.level {
  font-size: 20rpx;
  color: #4fc3f7;
}

.exp-bar {
  flex: 1;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  overflow: hidden;
}

.exp-fill {
  height: 100%;
  background: linear-gradient(90deg, #4caf50, #8bc34a);
  border-radius: 4rpx;
}

/* 战力显示 */
.power-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.power-label {
  font-size: 22rpx;
  color: #888;
}

.power-value {
  font-size: 36rpx;
  color: #ffd700;
  font-weight: bold;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

/* 货币栏 */
.currency-section {
  display: flex;
  justify-content: space-around;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.currency-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.currency-item .icon {
  font-size: 24rpx;
}

.currency-item .value {
  font-size: 22rpx;
  color: #fff;
}

.currency-item .add {
  font-size: 18rpx;
  color: #4caf50;
}

.currency-item .max {
  font-size: 18rpx;
  color: #666;
}

/* 主功能按钮 */
.main-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.action-btn.large {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  transition: all 0.3s;
}

.action-btn.large:active {
  transform: scale(0.98);
}

.action-btn.primary {
  background: linear-gradient(135deg, rgba(233, 30, 99, 0.3), rgba(255, 87, 34, 0.2));
  border-color: rgba(233, 30, 99, 0.5);
}

.action-btn.large .btn-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.btn-content {
  text-align: left;
}

.btn-title {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
  display: block;
}

.btn-desc {
  font-size: 20rpx;
  color: #888;
  display: block;
  margin-top: 4rpx;
}

/* 功能网格 */
.action-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.grid-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 8rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  transition: all 0.3s;
}

.grid-btn:active {
  background: rgba(255, 255, 255, 0.08);
  transform: scale(0.95);
}

.grid-btn .icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.grid-btn .label {
  font-size: 20rpx;
  color: #888;
}

/* 调试栏 */
.debug-bar {
  margin-top: auto;
  padding-top: 12rpx;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
}

.debug-btn {
  width: 100%;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #666;
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #1a1a2e;
  border-radius: 20rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
  max-width: 80%;
  max-height: 80%;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.modal-close {
  font-size: 32rpx;
  color: #888;
  padding: 10rpx;
}

/* 充值弹窗 */
.recharge-modal {
  width: 600rpx;
}

.recharge-packages {
  max-height: 400rpx;
  padding: 20rpx;
}

.package-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.package-item {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
  position: relative;
  border: 1px solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s;
}

.package-item:active {
  transform: scale(0.95);
}

.package-item.hot {
  border-color: rgba(255, 152, 0, 0.5);
}

.package-item.best-value {
  border-color: rgba(255, 215, 0, 0.5);
  background: linear-gradient(135deg, rgba(255, 215, 0, 0.1), rgba(255, 140, 0, 0.05));
}

.package-badge {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 18rpx;
  padding: 4rpx 12rpx;
  border-radius: 0 14rpx 0 10rpx;
  background: linear-gradient(135deg, #ffd700, #ff8c00);
  color: #000;
}

.package-name {
  font-size: 24rpx;
  color: #fff;
  display: block;
}

.package-bonus {
  font-size: 20rpx;
  color: #ffd700;
  display: block;
  margin-top: 8rpx;
}

.package-price {
  margin-top: 12rpx;
}

.price-symbol {
  font-size: 20rpx;
  color: #ffd700;
}

.price-value {
  font-size: 32rpx;
  color: #ffd700;
  font-weight: bold;
}

/* GM面板 */
.gm-modal {
  width: 400rpx;
  padding: 0;
}

.gm-section {
  padding: 20rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.gm-section-title {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-bottom: 12rpx;
}

.gm-buttons {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.gm-btn {
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 10rpx;
  font-size: 22rpx;
  color: #fff;
}

.gm-btn.danger {
  background: rgba(244, 67, 54, 0.2);
  border-color: rgba(244, 67, 54, 0.3);
  color: #f44336;
}

.gm-data {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.gm-data text {
  font-size: 22rpx;
  color: #fff;
}
