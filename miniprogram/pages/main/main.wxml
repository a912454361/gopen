<!--游戏主页面 - 横屏3D粒子效果-->
<view class="landscape-container">
  
  <!-- 左侧游戏画布区域 -->
  <view class="game-area">
    <canvas 
      type="webgl"
      id="gameCanvas"
      class="game-canvas"
      bindtap="onCanvasTap"
    ></canvas>
    
    <!-- 画布内覆盖UI -->
    <view class="canvas-overlay">
      <!-- 画质选择 -->
      <view class="quality-bar">
        <text class="quality-label">画质</text>
        <text class="quality-btn {{quality === 'low' ? 'active' : ''}}" 
              data-quality="low" bindtap="setQuality">低</text>
        <text class="quality-btn {{quality === 'medium' ? 'active' : ''}}" 
              data-quality="medium" bindtap="setQuality">中</text>
        <text class="quality-btn {{quality === 'high' ? 'active' : ''}}" 
              data-quality="high" bindtap="setQuality">高</text>
        <text class="quality-btn {{quality === 'ultra' ? 'active' : ''}}" 
              data-quality="ultra" bindtap="setQuality">极致</text>
      </view>
      
      <!-- 粒子数显示 -->
      <view class="particle-display">
        <text>粒子: {{particleCount}}</text>
      </view>
    </view>
  </view>

  <!-- 右侧信息面板 -->
  <view class="info-panel">
    <!-- 用户信息卡片 -->
    <view class="user-card">
      <view class="user-header">
        <view class="avatar-container">
          <image class="avatar" src="/images/avatar-default.png" mode="aspectFill" />
          <view class="vip-badge" wx:if="{{user.vip > 0}}">VIP{{user.vip}}</view>
        </view>
        <view class="user-info">
          <text class="nickname">{{user.nickname}}</text>
          <view class="level-bar">
            <text class="level">Lv.{{user.level}}</text>
            <view class="exp-bar">
              <view class="exp-fill" style="width: {{user.expPercent || 50}}%"></view>
            </view>
          </view>
        </view>
      </view>
      
      <!-- 战力显示 -->
      <view class="power-section">
        <text class="power-label">战力</text>
        <text class="power-value">{{user.power}}</text>
      </view>
      
      <!-- 货币栏 -->
      <view class="currency-section">
        <view class="currency-item" bindtap="showRecharge">
          <text class="icon">💰</text>
          <text class="value">{{user.gold}}</text>
          <text class="add">+</text>
        </view>
        <view class="currency-item" bindtap="showRecharge">
          <text class="icon">💎</text>
          <text class="value">{{user.gem}}</text>
          <text class="add">+</text>
        </view>
        <view class="currency-item">
          <text class="icon">⚡</text>
          <text class="value">{{user.energy}}</text>
          <text class="max">/200</text>
        </view>
      </view>
    </view>

    <!-- 主功能按钮 -->
    <view class="main-actions">
      <button class="action-btn large primary" bindtap="goToStory">
        <text class="btn-icon">⚔️</text>
        <view class="btn-content">
          <text class="btn-title">开始冒险</text>
          <text class="btn-desc">体验主线剧情</text>
        </view>
      </button>
      
      <button class="action-btn large" bindtap="goToStage">
        <text class="btn-icon">🏰</text>
        <view class="btn-content">
          <text class="btn-title">闯关挑战</text>
          <text class="btn-desc">战力碾压过关</text>
        </view>
      </button>
    </view>

    <!-- 功能网格 -->
    <view class="action-grid">
      <button class="grid-btn" bindtap="goToRanking">
        <text class="icon">🏆</text>
        <text class="label">排行榜</text>
      </button>
      <button class="grid-btn" bindtap="goToArena">
        <text class="icon">⚡</text>
        <text class="label">竞技场</text>
      </button>
      <button class="grid-btn" bindtap="goToGuild">
        <text class="icon">🏯</text>
        <text class="label">战盟</text>
      </button>
      <button class="grid-btn" bindtap="goToPet">
        <text class="icon">🐉</text>
        <text class="label">宠物</text>
      </button>
      <button class="grid-btn" bindtap="goToFriend">
        <text class="icon">👥</text>
        <text class="label">好友</text>
      </button>
      <button class="grid-btn" bindtap="showRecharge">
        <text class="icon">💎</text>
        <text class="label">充值</text>
      </button>
    </view>

    <!-- 底部调试按钮 -->
    <view class="debug-bar">
      <button class="debug-btn" bindtap="showGMPanel">🔧 调试</button>
    </view>
  </view>

  <!-- 充值弹窗 -->
  <view class="modal-overlay" wx:if="{{showRecharge}}" bindtap="hideRecharge">
    <view class="modal-content recharge-modal" catchtap>
      <view class="modal-header">
        <text class="modal-title">💎 充值中心</text>
        <text class="modal-close" bindtap="hideRecharge">✕</text>
      </view>
      
      <scroll-view class="recharge-packages" scroll-y>
        <view class="package-grid">
          <view class="package-item {{item.recommended ? 'recommended' : ''}} {{item.hot ? 'hot' : ''}} {{item.bestValue ? 'best-value' : ''}}" 
                wx:for="{{packages}}" 
                wx:key="id"
                data-id="{{item.id}}"
                bindtap="handleRecharge">
            <view class="package-badge" wx:if="{{item.recommended || item.hot || item.bestValue}}">
              {{item.bestValue ? '最超值' : item.hot ? '热卖' : '推荐'}}
            </view>
            <text class="package-name">{{item.name}}</text>
            <text class="package-bonus">赠送{{item.bonus}}</text>
            <view class="package-price">
              <text class="price-symbol">¥</text>
              <text class="price-value">{{item.price}}</text>
            </view>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- GM面板 -->
  <view class="modal-overlay" wx:if="{{showGM}}" bindtap="hideGM">
    <view class="modal-content gm-modal" catchtap>
      <view class="modal-header">
        <text class="modal-title">🔧 GM调试面板</text>
        <text class="modal-close" bindtap="hideGM">✕</text>
      </view>
      
      <view class="gm-section">
        <text class="gm-section-title">添加货币</text>
        <view class="gm-buttons">
          <button class="gm-btn" data-type="gold" bindtap="gmAddCurrency">+10000 💰</button>
          <button class="gm-btn" data-type="gem" bindtap="gmAddCurrency">+10000 💎</button>
          <button class="gm-btn" data-type="energy" bindtap="gmAddCurrency">+100 ⚡</button>
        </view>
      </view>
      
      <view class="gm-section">
        <text class="gm-section-title">其他操作</text>
        <view class="gm-buttons">
          <button class="gm-btn danger" bindtap="gmReset">重置数据</button>
        </view>
      </view>
      
      <view class="gm-section">
        <text class="gm-section-title">用户数据</text>
        <view class="gm-data">
          <text>UID: {{user.uid}}</text>
          <text>等级: {{user.level}}</text>
          <text>VIP: {{user.vip}}</text>
          <text>战力: {{user.power}}</text>
        </view>
      </view>
    </view>
  </view>

</view>
