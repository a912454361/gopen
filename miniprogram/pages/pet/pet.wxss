/* 宠物页面样式 */
.pet-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a102a 0%, #0f0f1a 100%);
  padding: 20rpx;
}

/* 宠物展示 */
.pet-display {
  text-align: center;
  padding: 40rpx;
  background: rgba(138, 43, 226, 0.1);
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  border: 1px solid rgba(138, 43, 226, 0.2);
}

.pet-avatar {
  position: relative;
  display: inline-block;
}

.pet-avatar .avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  border: 4px solid #8a2be2;
  box-shadow: 0 0 30rpx rgba(138, 43, 226, 0.5);
}

.level-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  background: linear-gradient(135deg, #ffd700, #ff8c00);
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.pet-name {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
  display: block;
  margin-top: 20rpx;
}

.pet-power {
  font-size: 28rpx;
  color: #ffd700;
  display: block;
  margin-top: 10rpx;
}

/* 状态条 */
.status-bars {
  margin-top: 30rpx;
  text-align: left;
}

.status-item {
  margin-bottom: 16rpx;
}

.status-item .label {
  font-size: 24rpx;
  color: #888;
  display: inline-block;
  width: 100rpx;
}

.status-item .bar {
  display: inline-block;
  width: 300rpx;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  overflow: hidden;
  vertical-align: middle;
  margin: 0 16rpx;
}

.status-item .fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s;
}

.status-item .fill.hunger {
  background: linear-gradient(90deg, #4caf50, #8bc34a);
}

.status-item .fill.mood {
  background: linear-gradient(90deg, #e91e63, #ff5722);
}

.status-item .fill.exp {
  background: linear-gradient(90deg, #2196f3, #03a9f4);
}

.status-item .value {
  font-size: 22rpx;
  color: #666;
}

/* 技能 */
.skills-section {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.skills-list {
  display: flex;
  gap: 16rpx;
}

.skill-item {
  flex: 1;
  background: linear-gradient(135deg, rgba(138, 43, 226, 0.3), rgba(75, 0, 130, 0.2));
  border: 1px solid rgba(138, 43, 226, 0.4);
  border-radius: 12rpx;
  padding: 16rpx;
  text-align: center;
}

.skill-name {
  font-size: 26rpx;
  color: #da70d6;
}

/* 操作按钮 */
.actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #fff;
}

.action-btn.primary {
  background: linear-gradient(135deg, #4caf50, #2e7d32);
  border: none;
}

.action-btn.special {
  background: linear-gradient(135deg, #ffd700, #ff8c00);
  border: none;
  color: #000;
  font-weight: bold;
}

/* 宠物列表 */
.pet-list-section {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 20rpx;
}

.pet-list {
  white-space: nowrap;
}

.pet-item {
  display: inline-block;
  width: 160rpx;
  text-align: center;
  padding: 16rpx;
  margin-right: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
  transition: all 0.3s;
}

.pet-item.active {
  background: rgba(138, 43, 226, 0.2);
  border-color: rgba(138, 43, 226, 0.5);
}

.mini-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.mini-name {
  font-size: 24rpx;
  color: #fff;
  display: block;
  margin-top: 10rpx;
}

.mini-level {
  font-size: 20rpx;
  color: #888;
}

/* 喂养弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 85%;
  background: #1a1a2e;
  border-radius: 20rpx;
  padding: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  color: #fff;
  text-align: center;
  display: block;
  margin-bottom: 24rpx;
}

.food-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.food-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.food-item.common {
  background: rgba(76, 175, 80, 0.1);
  border-color: rgba(76, 175, 80, 0.3);
}

.food-item.rare {
  background: rgba(33, 150, 243, 0.1);
  border-color: rgba(33, 150, 243, 0.3);
}

.food-item.epic {
  background: rgba(156, 39, 176, 0.1);
  border-color: rgba(156, 39, 176, 0.3);
}

.food-item.legendary {
  background: rgba(255, 215, 0, 0.1);
  border-color: rgba(255, 215, 0, 0.3);
}

.food-name {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.food-effect {
  font-size: 22rpx;
  color: #888;
}

.food-cost {
  font-size: 26rpx;
  color: #ffd700;
}

.cancel-btn {
  margin-top: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #888;
  border-radius: 20rpx;
}
