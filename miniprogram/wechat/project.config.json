{
  "name": "inkcards-wechat",
  "version": "1.0.0",
  "description": "万古长夜 - 国风粒子卡牌游戏 - 微信小程序",
  "appid": "wx_INKCARDS_APPID",
  "projectname": "inkcards-wechat",
