/* 战盟页面样式 */
.guild-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1a0a 0%, #0f0f1a 100%);
  padding: 20rpx;
}

/* 我的战盟 */
.my-guild {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  padding: 20rpx;
}

.guild-header {
  display: flex;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.guild-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  border: 2px solid #4caf50;
}

.guild-info {
  flex: 1;
  margin-left: 20rpx;
}

.guild-name {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
  display: block;
}

.guild-level {
  font-size: 24rpx;
  color: #4caf50;
  margin-right: 16rpx;
}

.guild-members {
  font-size: 24rpx;
  color: #888;
}

.guild-power {
  text-align: center;
}

.guild-power .value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffd700;
  display: block;
}

.guild-power .label {
  font-size: 22rpx;
  color: #888;
}

/* 公告 */
.guild-notice {
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.1);
}

.guild-notice .title {
  font-size: 26rpx;
  color: #4caf50;
  display: block;
  margin-bottom: 10rpx;
}

.guild-notice .content {
  font-size: 28rpx;
  color: #ccc;
  line-height: 1.6;
}

/* 成员列表 */
.members-section {
  padding: 20rpx 0;
}

.section-title {
  font-size: 28rpx;
  color: #fff;
  display: block;
  margin-bottom: 16rpx;
}

.members-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.member-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.03);
  padding: 16rpx;
  border-radius: 12rpx;
}

.member-item .avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.member-item .info {
  flex: 1;
  margin-left: 16rpx;
}

.member-item .name {
  font-size: 28rpx;
  color: #fff;
  display: block;
}

.member-item .level {
  font-size: 22rpx;
  color: #888;
}

.member-item .role {
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
}

.member-item .role.leader {
  background: rgba(255, 215, 0, 0.2);
  color: #ffd700;
}

.member-item .role.vice_leader {
  background: rgba(156, 39, 176, 0.2);
  color: #e040fb;
}

.member-item .role.elder {
  background: rgba(33, 150, 243, 0.2);
  color: #4fc3f7;
}

.member-item .power {
  font-size: 26rpx;
  color: #ffd700;
  margin-left: 16rpx;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  background: rgba(76, 175, 80, 0.2);
  color: #4caf50;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.action-btn.danger {
  background: rgba(244, 67, 54, 0.2);
  color: #f44336;
}

/* 未加入战盟 */
.no-guild {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #fff;
  display: block;
  margin-top: 30rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #888;
  display: block;
  margin-top: 16rpx;
}

.btns {
  display: flex;
  gap: 30rpx;
  margin-top: 60rpx;
}

.create-btn, .join-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 30rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.create-btn {
  background: linear-gradient(135deg, #4caf50, #2e7d32);
  color: #fff;
}

.join-btn {
  background: rgba(76, 175, 80, 0.2);
  color: #4caf50;
  border: 1px solid #4caf50;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: #1a1a2e;
  border-radius: 20rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  color: #fff;
  text-align: center;
  display: block;
  margin-bottom: 30rpx;
}

.input {
  width: 100%;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx;
  color: #fff;
  font-size: 30rpx;
}

.cost {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #e040fb;
  margin-top: 16rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-btns button {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
}

.cancel {
  background: rgba(255, 255, 255, 0.1);
  color: #888;
}

.confirm {
  background: linear-gradient(135deg, #4caf50, #2e7d32);
  color: #fff;
}

.guild-list {
  max-height: 500rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.guild-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.03);
  padding: 20rpx;
  border-radius: 12rpx;
  border: 1px solid rgba(76, 175, 80, 0.2);
}

.guild-item .name {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.guild-item .level {
  font-size: 24rpx;
  color: #4caf50;
  margin-right: 16rpx;
}

.guild-item .members {
  font-size: 24rpx;
  color: #888;
  margin-right: 16rpx;
}

.guild-item .power {
  font-size: 24rpx;
  color: #ffd700;
}
