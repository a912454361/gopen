/* 成就页面样式 */

.header-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
}

.progress-section {
  margin: 0 24rpx 32rpx;
  padding: 20rpx;
}

.achievements-list {
  padding: 0 24rpx;
}

.achievement-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #1a1a2e;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.2);
}

.achievement-locked {
  opacity: 0.5;
  filter: grayscale(100%);
}

.achievement-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
  background: rgba(255, 215, 0, 0.1);
  border-radius: 16rpx;
}

.achievement-info {
  flex: 1;
}

.achievement-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.achievement-desc {
  font-size: 24rpx;
  color: #aaaaaa;
}

.achievement-status {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #10b981;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status-icon {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
}
