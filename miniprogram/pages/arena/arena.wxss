/* 横屏竞技场页面样式 */

.arena-landscape {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  background: linear-gradient(135deg, #0a0a2e 0%, #1a1a2e 50%, #0f0f1a 100%);
}

/* 左侧竞技场信息 */
.arena-info-area {
  width: 220rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 1px solid rgba(138, 43, 226, 0.2);
}

.season-badge {
  background: rgba(138, 43, 226, 0.3);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
}

.season-badge text {
  font-size: 22rpx;
  color: #da70d6;
}

.rank-display {
  text-align: center;
  margin-bottom: 20rpx;
}

.rank-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffd700;
  display: block;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.5);
}

.rank-label {
  font-size: 22rpx;
  color: #888;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.stat {
  text-align: center;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 10rpx;
}

.stat .num {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  display: block;
}

.stat .text {
  font-size: 18rpx;
  color: #888;
}

.best-rank {
  margin-top: auto;
  text-align: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 10rpx;
  width: 100%;
}

.best-rank .label {
  font-size: 20rpx;
  color: #888;
  display: block;
}

.best-rank .value {
  font-size: 32rpx;
  color: #da70d6;
  font-weight: bold;
}

/* 中间对手列表 */
.opponents-area {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

.area-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.area-header .title {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.area-header .refresh {
  font-size: 24rpx;
  color: #da70d6;
  padding: 6rpx 16rpx;
  background: rgba(138, 43, 226, 0.2);
  border-radius: 10rpx;
}

.opponents-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.opponent-card {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
  gap: 16rpx;
  transition: all 0.3s;
}

.opponent-card:active {
  background: rgba(138, 43, 226, 0.2);
  border-color: rgba(138, 43, 226, 0.5);
}

.opponent-card .avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  border: 2px solid #da70d6;
}

.opponent-card .info {
  flex: 1;
}

.opponent-card .name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
  display: block;
}

.opponent-card .level {
  font-size: 20rpx;
  color: #888;
}

.power-info, .rank-info {
  text-align: center;
  padding: 8rpx 12rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 8rpx;
}

.power-info .power, .rank-info .rank {
  font-size: 24rpx;
  color: #ffd700;
  font-weight: bold;
  display: block;
}

.power-info .label, .rank-info .label {
  font-size: 16rpx;
  color: #888;
}

.challenge-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #8a2be2, #4b0082);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
}

.empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
  font-size: 26rpx;
}

/* 右侧赛季奖励 */
.rewards-area {
  width: 250rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  border-left: 1px solid rgba(255, 255, 255, 0.1);
}

.area-title {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.rewards-list {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.reward-item {
  display: flex;
  flex-direction: column;
  padding: 12rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 10rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.reward-item.top {
  background: rgba(255, 215, 0, 0.1);
  border-color: rgba(255, 215, 0, 0.3);
}

.reward-item .rank {
  font-size: 22rpx;
  color: #ffd700;
  margin-bottom: 4rpx;
}

.reward-item .prize {
  font-size: 20rpx;
  color: #888;
}

.claim-btn {
  margin-top: auto;
  padding: 16rpx;
  background: linear-gradient(135deg, #8a2be2, #4b0082);
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
}

/* 战斗遮罩 */
.battle-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.battle-animation {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sword-icon {
  font-size: 80rpx;
  animation: rotate 1s linear infinite;
}

.battle-text {
  font-size: 32rpx;
  color: #ffd700;
  margin-top: 20rpx;
  animation: pulse 0.5s ease-in-out infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}
