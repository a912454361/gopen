/* 统计页面样式 */

.header-section {
  padding: 32rpx;
}

.card-title {
  display: block;
  font-size: 28rpx;
  color: #aaaaaa;
  margin-bottom: 20rpx;
}

.stat-block {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.stat-block:last-child {
  border-bottom: none;
}

.stat-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #aaaaaa;
}

.stat-value-text {
  flex: 1;
  font-size: 28rpx;
  color: #ffffff;
  text-align: right;
}

.stat-bar-container {
  flex: 1;
  padding: 0 16rpx;
}

.stat-value {
  width: 60rpx;
  text-align: right;
  font-size: 28rpx;
  color: #ffd700;
}

/* 战斗统计 */
.battle-stats {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.battle-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.battle-stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #10b981;
}

.battle-stat-value.danger {
  color: #ef4444;
}

.battle-stat-value.gold {
  color: #ffd700;
}

.battle-stat-label {
  font-size: 24rpx;
  color: #aaaaaa;
  margin-top: 8rpx;
}

/* 结局列表 */
.endings-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.ending-item {
  flex: 1;
  min-width: 140rpx;
  padding: 20rpx;
  background: #252540;
  border-radius: 12rpx;
  text-align: center;
}

.ending-item.locked {
  opacity: 0.5;
}

.ending-name {
  display: block;
  font-size: 24rpx;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.ending-status {
  font-size: 28rpx;
}

.ending-item.unlocked .ending-status {
  color: #10b981;
}

.ending-item.locked .ending-status {
  color: #666666;
}

/* 重置区域 */
.reset-section {
  padding: 48rpx 24rpx;
}

.btn-danger {
  background: #ef4444;
  color: #ffffff;
}
