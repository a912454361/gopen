<!--排行榜页面-->
<view class="ranking-page">
  <!-- Tab切换 -->
  <view class="tabs">
    <view 
      wx:for="{{tabs}}" 
      wx:key="key"
      class="tab-item {{currentTab === item.key ? 'active' : ''}}"
      data-type="{{item.key}}"
      bindtap="onTabChange"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <!-- 排行榜列表 -->
  <view wx:else class="ranking-list">
    <view 
      wx:for="{{rankings}}" 
      wx:key="uid"
      class="ranking-item {{item.rank <= 3 ? 'top' + item.rank : ''}}"
      data-uid="{{item.uid}}"
      bindtap="viewPlayer"
    >
      <!-- 排名 -->
      <view class="rank {{item.rank === 1 ? 'gold' : item.rank === 2 ? 'silver' : item.rank === 3 ? 'bronze' : ''}}">
        <text wx:if="{{item.rank <= 3}}">👑</text>
        <text wx:else>{{item.rank}}</text>
      </view>

      <!-- 玩家信息 -->
      <view class="player-info">
        <image class="avatar" src="{{item.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="info">
          <view class="name-row">
            <text class="name">{{item.nickname || '剑客' + item.uid}}</text>
            <text wx:if="{{item.vip > 0}}" class="vip">VIP{{item.vip}}</text>
          </view>
          <text class="level">Lv.{{item.level}}</text>
        </view>
      </view>

      <!-- 战力值 -->
      <view class="power">
        <text class="value">{{item.power || item.rank || 0}}</text>
        <text class="unit">{{currentTab === 'power' ? '战力' : currentTab === 'arena' ? '积分' : currentTab === 'chapter' ? '章' : '战力'}}</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:if="{{rankings.length === 0}}" class="empty">
      <text>暂无数据</text>
    </view>
  </view>

  <!-- 我的排名 -->
  <view class="my-rank">
    <text class="title">我的排名</text>
    <text class="rank">第 {{myRank || '--'}} 名</text>
  </view>
</view>
