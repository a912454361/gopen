/* 首页样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1A1A2E 0%, #0A0A0F 100%);
  padding-bottom: 160rpx;
}

/* Hero */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx 48rpx;
}

.logo-container {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
}

.logo-glow {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  left: -20rpx;
  top: -20rpx;
  background: radial-gradient(circle, rgba(212, 175, 55, 0.3) 0%, transparent 70%);
  border-radius: 50%;
}

.logo-icon {
  position: relative;
  font-size: 80rpx;
  line-height: 160rpx;
  text-align: center;
  z-index: 1;
}

.title {
  font-size: 64rpx;
  font-weight: 700;
  color: #D4AF37;
  letter-spacing: 12rpx;
  text-shadow: 0 4rpx 20rpx rgba(212, 175, 55, 0.3);
}

.subtitle {
  font-size: 24rpx;
  color: #6B7280;
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

/* 玩家卡片 */
.player-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 0 32rpx 32rpx;
}

.player-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #D4AF37, #B8960F);
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 24rpx;
}

.avatar-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #000;
}

.player-detail {
  display: flex;
  flex-direction: column;
}

.player-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #F5F5F5;
}

.player-level {
  font-size: 22rpx;
  color: #6B7280;
  margin-top: 4rpx;
}

.currency-row {
  display: flex;
  gap: 32rpx;
}

.currency-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.currency-icon {
  font-size: 24rpx;
}

.currency-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #D4AF37;
}

/* 主菜单网格 */
.menu-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.menu-item {
  background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255,255,255,0.1);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.menu-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.menu-icon.battle {
  background: linear-gradient(135deg, #E74C3C, #C0392B);
}

.menu-icon.cards {
  background: linear-gradient(135deg, #9B59B6, #8E44AD);
}

.menu-icon.draw {
  background: linear-gradient(135deg, #F39C12, #D68910);
}

.menu-icon.rank {
  background: linear-gradient(135deg, #3498DB, #2980B9);
}

.menu-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #F5F5F5;
  margin-bottom: 4rpx;
}

.menu-subtitle {
  font-size: 22rpx;
  color: #6B7280;
}

/* 公告 */
.announcement {
  display: flex;
  align-items: center;
  margin: 0 32rpx 32rpx;
  padding: 24rpx 32rpx;
  background: linear-gradient(90deg, rgba(79, 70, 229, 0.2), rgba(139, 92, 246, 0.2));
}

.announcement-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.announcement-text {
  flex: 1;
  font-size: 24rpx;
  color: #F5F5F5;
}

.announcement-btn {
  font-size: 24rpx;
  font-weight: 600;
  color: #D4AF37;
  padding: 8rpx 24rpx;
  background: rgba(212, 175, 55, 0.2);
  border-radius: 24rpx;
}

/* WebView 入口 */
.webview-entry {
  margin: 0 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.1), rgba(139, 92, 246, 0.1));
}

.webview-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #F5F5F5;
  margin-bottom: 8rpx;
}

.webview-desc {
  font-size: 24rpx;
  color: #6B7280;
}

.webview-arrow {
  font-size: 48rpx;
  color: #D4AF37;
  margin-top: 16rpx;
}
