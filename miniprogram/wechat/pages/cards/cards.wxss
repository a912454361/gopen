/* 卡牌页面样式 */

.container {
  min-height: 100vh;
  background-color: var(--color-bg);
}

.filter-bar {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  overflow-x: auto;
  white-space: nowrap;
  background-color: var(--color-bg-card);
  border-bottom: 1rpx solid var(--color-border);
}

.filter-item {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
  background-color: rgba(255,255,255,0.05);
  flex-shrink: 0;
}

.filter-item.active {
  background-color: var(--color-primary);
  color: #000;
}

.cards-scroll {
  height: calc(100vh - 120rpx);
}

.cards-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 24rpx;
}

.card-item {
  background-color: var(--color-bg-card);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid var(--color-border);
}

.card-image {
  height: 280rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.card-image image {
  width: 100%;
  height: 100%;
}

.card-info {
  padding: 20rpx;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 8rpx;
}

.card-tags {
  margin-bottom: 8rpx;
}

.card-stats {
  display: flex;
  gap: 16rpx;
}

.stat {
  font-size: 22rpx;
  color: var(--color-text-muted);
}
