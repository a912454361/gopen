/* 横屏战斗页面样式 */

.battle-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  background: linear-gradient(180deg, #0a0a1a 0%, #1a1a2e 50%, #0a0a1a 100%);
  overflow: hidden;
}

/* 战斗场景 */
.battle-scene {
  flex: 1;
  position: relative;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 40rpx;
}

/* 敌人区域 */
.enemy-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.enemy-info {
  text-align: center;
}

.enemy-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.enemy-name {
  font-size: 32rpx;
  color: #ff6b6b;
  font-weight: bold;
  text-shadow: 0 0 10px rgba(255, 107, 107, 0.5);
}

.enemy-level {
  font-size: 24rpx;
  color: #888;
}

.boss-badge {
  font-size: 20rpx;
  background: linear-gradient(135deg, #ffd700, #ff8c00);
  color: #000;
  padding: 4rpx 16rpx;
  border-radius: 10rpx;
  font-weight: bold;
  animation: pulse 1s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(1.05); }
}

/* 敌人形象 */
.enemy-sprite {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.enemy-shadow {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 30rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
}

.enemy-image {
  width: 100%;
  height: 100%;
}

.enemy-sprite.boss .enemy-image {
  width: 250rpx;
  height: 250rpx;
  filter: drop-shadow(0 0 20px rgba(255, 107, 107, 0.5));
}

/* 受击特效 */
.hit-effect {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 150%;
  height: 150%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 70%);
  animation: hitFlash 0.2s ease-out;
  pointer-events: none;
}

@keyframes hitFlash {
  0% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
  50% { opacity: 1; }
  100% { opacity: 0; transform: translate(-50%, -50%) scale(1.5); }
}

/* 玩家区域 */
.player-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.player-sprite {
  position: relative;
  width: 150rpx;
  height: 150rpx;
}

.player-shadow {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 20rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
}

.player-image {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 0 10px rgba(79, 195, 247, 0.5));
}

.player-info {
  text-align: center;
}

.player-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.player-name {
  font-size: 28rpx;
  color: #4fc3f7;
  font-weight: bold;
}

.player-level {
  font-size: 22rpx;
  color: #888;
}

/* 血条 */
.hp-bar, .mp-bar {
  position: relative;
  width: 250rpx;
  height: 24rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 12rpx;
  overflow: hidden;
  border: 2px solid rgba(255, 255, 255, 0.1);
}

.hp-bar.player-hp {
  margin-bottom: 8rpx;
}

.hp-fill {
  height: 100%;
  background: linear-gradient(90deg, #4caf50, #8bc34a);
  border-radius: 10rpx;
  transition: width 0.3s;
}

.enemy-hp .hp-fill {
  background: linear-gradient(90deg, #f44336, #ff5722);
}

.mp-fill {
  height: 100%;
  background: linear-gradient(90deg, #2196f3, #03a9f4);
  border-radius: 10rpx;
  transition: width 0.3s;
}

.hp-text, .mp-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 18rpx;
  color: #fff;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
}

/* 战斗日志 */
.battle-log {
  width: 280rpx;
  background: rgba(0, 0, 0, 0.6);
  border-left: 1px solid rgba(255, 255, 255, 0.1);
}

.log-scroll {
  height: 100%;
  padding: 16rpx;
}

.log-item {
  font-size: 20rpx;
  color: #aaa;
  line-height: 1.6;
  margin-bottom: 8rpx;
  padding-left: 16rpx;
  border-left: 2px solid rgba(255, 255, 255, 0.1);
}

/* 控制面板 */
.control-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 280rpx;
  padding: 20rpx 40rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
}

/* 准备面板 */
.ready-panel {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 30rpx;
}

.stage-info {
  font-size: 28rpx;
  color: #ffd700;
}

.start-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #e91e63, #ff5722);
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.flee-btn {
  padding: 20rpx 40rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #888;
}

/* 战斗面板 */
.battle-panel {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-buttons {
  display: flex;
  justify-content: center;
  gap: 16rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2px solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  transition: all 0.2s;
}

.action-btn:active {
  transform: scale(0.95);
  background: rgba(255, 255, 255, 0.1);
}

.action-btn .icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.action-btn .label {
  font-size: 22rpx;
  color: #fff;
}

.action-btn .cost {
  font-size: 18rpx;
  color: #4fc3f7;
  margin-top: 2rpx;
}

.action-btn.attack {
  border-color: rgba(244, 67, 54, 0.5);
}

.action-btn.skill {
  border-color: rgba(156, 39, 176, 0.5);
}

.action-btn.auto.active {
  background: rgba(76, 175, 80, 0.2);
  border-color: rgba(76, 175, 80, 0.5);
}

.status-bar {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.turn, .speed {
  font-size: 22rpx;
  color: #888;
}

.speed {
  cursor: pointer;
  padding: 4rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 10rpx;
}

/* 结束面板 */
.end-panel {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
}

.result-text {
  font-size: 36rpx;
  font-weight: bold;
}

.end-panel.victory .result-text {
  color: #ffd700;
  text-shadow: 0 0 20px rgba(255, 215, 0, 0.5);
}

.end-panel.defeat .result-text {
  color: #f44336;
}

.retry-btn, .back-btn {
  padding: 16rpx 40rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.retry-btn {
  background: linear-gradient(135deg, #4caf50, #2e7d32);
  color: #fff;
}

.back-btn {
  background: rgba(255, 255, 255, 0.1);
  color: #888;
}
