/* 游戏页面样式 */

.game-container {
  padding: 0;
  padding-bottom: 40rpx;
}

/* 视频区域 */
.video-section {
  position: relative;
  width: 100%;
  height: 420rpx;
  overflow: hidden;
}

.story-video {
  width: 100%;
  height: 100%;
}

.video-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: linear-gradient(transparent, rgba(15, 15, 26, 1));
}

/* 章节标题 */
.chapter-header {
  padding: 32rpx;
  text-align: center;
}

.node-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
  margin-top: 16rpx;
  text-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3);
}

/* 剧情区域 */
.story-section {
  padding: 0 24rpx;
}

.description-card {
  margin-bottom: 32rpx;
}

.description-text {
  font-size: 30rpx;
  line-height: 48rpx;
  color: #ffffff;
}

/* 选择区域 */
.choices-section {
  margin-top: 24rpx;
}

.choices-title {
  display: block;
  font-size: 28rpx;
  color: #aaaaaa;
  margin-bottom: 20rpx;
}

.choice-btn {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  background: #1a1a2e;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.choice-btn:active {
  border-color: #ffd700;
  background: #252540;
}

.choice-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd700, #c9a96e);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.choice-icon text {
  color: #0f0f1a;
  font-size: 28rpx;
  font-weight: bold;
}

.choice-text {
  flex: 1;
  font-size: 30rpx;
  color: #ffffff;
}

.choice-effects {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-left: 16rpx;
}

.effect-tag {
  font-size: 20rpx;
  color: #10b981;
  background: rgba(16, 185, 129, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 战斗界面 */
.battle-section {
  padding: 24rpx;
}

.enemy-info {
  margin-bottom: 24rpx;
}

.enemy-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.enemy-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #ef4444;
}

.enemy-hp-text {
  font-size: 26rpx;
  color: #aaaaaa;
}

.battle-log {
  min-height: 200rpx;
  margin-bottom: 24rpx;
}

.log-item {
  font-size: 26rpx;
  color: #aaaaaa;
  margin-bottom: 12rpx;
  padding: 8rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

.player-status {
  margin-bottom: 24rpx;
}

.status-row {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.status-item {
  display: flex;
  align-items: center;
}

.status-label {
  width: 40rpx;
  font-size: 24rpx;
  color: #aaaaaa;
}

.status-value {
  width: 100rpx;
  text-align: right;
  font-size: 24rpx;
  color: #ffffff;
}

.mp-bar {
  background: rgba(59, 130, 246, 0.3);
}

.hp-fill.mp {
  background: linear-gradient(90deg, #3b82f6, #60a5fa);
}

/* 技能区域 */
.skill-section {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.skill-btn {
  flex: 1;
  min-width: 140rpx;
  padding: 20rpx 16rpx;
  background: #252540;
  border-radius: 16rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.skill-btn:active {
  border-color: #ffd700;
}

.skill-btn.disabled {
  opacity: 0.5;
}

.skill-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.skill-name {
  display: block;
  font-size: 24rpx;
  color: #ffffff;
  margin-bottom: 4rpx;
}

.skill-cost {
  font-size: 20rpx;
  color: #666666;
}

/* 属性面板 */
.stats-panel {
  margin: 24rpx;
  margin-top: 32rpx;
}

.stats-title {
  display: block;
  font-size: 28rpx;
  color: #aaaaaa;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.stat-item {
  display: flex;
  align-items: center;
}

.stat-label {
  width: 100rpx;
  font-size: 26rpx;
  color: #aaaaaa;
}

.stat-bar {
  flex: 1;
  height: 16rpx;
  background: #252540;
  border-radius: 8rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.stat-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffd700, #c9a96e);
  border-radius: 8rpx;
}

.stat-value {
  width: 60rpx;
  text-align: right;
  font-size: 26rpx;
  color: #ffd700;
}

/* 继续区域 */
.continue-section {
  text-align: center;
  padding: 48rpx;
}

/* 动画 */
.fade-in {
  animation: fadeIn 0.3s ease forwards;
}

.fade-out {
  animation: fadeOut 0.3s ease forwards;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeOut {
  from { opacity: 1; transform: translateY(0); }
  to { opacity: 0; transform: translateY(-20rpx); }
}
