{
  "name": "gopen-ai-assistant",
  "version": "1.0.0",
  "description": "G open 智能创作助手 - AI对话、模型市场、会员系统",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:nsis": "electron-builder --win nsis --x64",
    "build:portable": "electron-builder --win portable --x64",
    "build:all": "electron-builder --win nsis portable --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "G Open Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-icon-builder": "^2.0.1"
  },
  "build": {
    "appId": "com.gopen.ai-assistant",
    "productName": "G Open AI助手",
    "copyright": "Copyright © 2024 G Open Team",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icons/win/icon.ico",
      "sign": null,
      "signingHashAlgorithms": ["sha256"],
      "certificateFile": null,
      "certificateSubjectName": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": true,
      "allowToChangeInstallationDirectory": false,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "G Open AI助手",
      "installerIcon": "assets/icons/win/icon.ico",
      "uninstallerIcon": "assets/icons/win/icon.ico",
      "installerHeaderIcon": "assets/icons/win/icon.ico",
      "deleteAppDataOnUninstall": true,
      "displayLanguageSelector": false,
      "installerLanguages": ["zh_CN", "en_US"],
      "language": "2052",
      "artifactName": "${productName}-Setup-${version}.exe",
      "include": null,
      "warningsAsErrors": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.exe"
    },
    "asar": true,
    "asarUnpack": [
      "dist/**/*"
    ],
    "extraMetadata": {
      "main": "main.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
