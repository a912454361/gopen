/**app.wxss**/
/* 全局样式 - 国风水墨主题 */

/* 色彩变量 */
page {
  --color-primary: #D4AF37;
  --color-secondary: #8B5CF6;
  --color-bg: #0A0A0F;
  --color-bg-card: #1A1A2E;
  --color-text: #F5F5F5;
  --color-text-muted: #6B7280;
  --color-border: #2D2D44;
  --color-success: #10B981;
  --color-error: #EF4444;
  
  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 容器 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background-color: var(--color-bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid var(--color-border);
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, var(--color-primary), #B8960F);
  color: #000;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
}

.btn-secondary {
  background-color: var(--color-bg-card);
  color: var(--color-text);
  border: 1rpx solid var(--color-border);
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
}

/* 标题 */
.title {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 8rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--color-border);
  margin: 32rpx 0;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  margin-right: 8rpx;
}

.tag-gold {
  background-color: rgba(212, 175, 55, 0.2);
  color: var(--color-primary);
}

.tag-purple {
  background-color: rgba(139, 92, 246, 0.2);
  color: #A78BFA;
}

.tag-red {
  background-color: rgba(239, 68, 68, 0.2);
  color: #F87171;
}

/* 加载中 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 64rpx;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 128rpx 64rpx;
  color: var(--color-text-muted);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

/* 阵营颜色 */
.faction-youming { color: #8B5CF6; }
.faction-kunlun { color: #3B82F6; }
.faction-penglai { color: #EC4899; }
.faction-manhuang { color: #F97316; }
.faction-wangu { color: #D4AF37; }

/* 品级颜色 */
.rarity-fan { color: #9CA3AF; }
.rarity-ling { color: #10B981; }
.rarity-xian { color: #3B82F6; }
.rarity-sheng { color: #A855F7; }
.rarity-wangu { color: #D4AF37; }

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.pulse {
  animation: pulse 2s infinite;
}
