# ============================================
# G open 智能创作助手 - 生产环境配置模板
# ============================================
# 复制此文件为 .env 并填写实际值

# ===================
# 服务基础配置
# ===================
NODE_ENV=production
PORT=9091
HOST=0.0.0.0

# ===================
# 数据库配置 (Supabase)
# ===================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ===================
# 对象存储配置 (阿里云 OSS)
# ===================
OSS_ACCESS_KEY_ID=your-oss-access-key-id
OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
OSS_REGION=oss-cn-beijing
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_BUCKET_PRIMARY=your-primary-bucket
OSS_BUCKET_SECONDARY=your-secondary-bucket

# ===================
# AI 模型配置
# ===================
# 豆包/字节跳动
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_MODEL_ENDPOINT=your-doubao-endpoint

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key

# Kimi (Moonshot)
KIMI_API_KEY=your-kimi-api-key

# 通义千问 (阿里云)
QWEN_API_KEY=your-qwen-api-key

# GLM (智谱)
GLM_API_KEY=your-glm-api-key

# 图像生成
IMAGE_GEN_API_KEY=your-image-gen-api-key

# 视频生成
VIDEO_GEN_API_KEY=your-video-gen-api-key

# ===================
# OAuth 配置
# ===================
# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# 微信开放平台
WECHAT_OPEN_APP_ID=your-wechat-app-id
WECHAT_OPEN_APP_SECRET=your-wechat-app-secret

# 支付宝
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key

# ===================
# 支付配置
# ===================
# 微信支付
WECHAT_PAY_MCH_ID=your-mch-id
WECHAT_PAY_API_KEY=your-wechat-pay-api-key
WECHAT_PAY_NOTIFY_URL=https://your-domain.com/api/v1/pay/wechat/notify

# 支付宝支付
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/pay/alipay/notify

# ===================
# 短信配置
# ===================
SMS_ACCESS_KEY=your-sms-access-key
SMS_SECRET_KEY=your-sms-secret-key
SMS_SIGN_NAME=G open创作助手
SMS_TEMPLATE_CODE=SMS_123456789

# ===================
# 安全配置
# ===================
JWT_SECRET=your-jwt-secret-key-at-least-32-characters
ADMIN_SECRET_KEY=GtAdmin2024SecretKey8888

# ===================
# Redis 配置 (可选)
# ===================
REDIS_URL=redis://localhost:6379

# ===================
# 日志配置
# ===================
LOG_LEVEL=info
LOG_FORMAT=json

# ===================
# CORS 配置
# ===================
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com

# ===================
# 前端配置
# ===================
EXPO_PUBLIC_BACKEND_BASE_URL=https://api.your-domain.com
