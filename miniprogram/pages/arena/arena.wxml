<!--竞技场页面-->
<view class="arena-page">
  <!-- 竞技场信息 -->
  <view class="arena-header">
    <view class="season">
      <text class="label">第{{arenaInfo?.season || 1}}赛季</text>
    </view>
    
    <view class="rank-info">
      <view class="rank-item">
        <text class="label">当前积分</text>
        <text class="value">{{arenaInfo?.rank || 1000}}</text>
      </view>
      <view class="rank-item">
        <text class="label">最高积分</text>
        <text class="value">{{arenaInfo?.best_rank || 1000}}</text>
      </view>
    </view>
    
    <view class="stats">
      <view class="stat">
        <text class="num">{{arenaInfo?.wins || 0}}</text>
        <text class="text">胜利</text>
      </view>
      <view class="stat">
        <text class="num">{{arenaInfo?.losses || 0}}</text>
        <text class="text">失败</text>
      </view>
      <view class="stat">
        <text class="num">{{arenaInfo?.streak || 0}}</text>
        <text class="text">连胜</text>
      </view>
    </view>
  </view>

  <!-- 对手列表 -->
  <view class="opponents-section">
    <view class="section-header">
      <text class="title">匹配对手</text>
      <text class="refresh" bindtap="refreshOpponents">刷新</text>
    </view>
    
    <view class="opponents-list">
      <view 
        wx:for="{{opponents}}" 
        wx:key="uid"
        class="opponent-card"
        data-uid="{{item.uid}}"
        bindtap="startBattle"
      >
        <image class="avatar" src="{{item.avatar || '/images/default-avatar.png'}}" mode="aspectFill" />
        <view class="info">
          <text class="name">{{item.nickname || '剑客'}}</text>
          <text class="level">Lv.{{item.level}}</text>
          <text class="power">战力: {{item.power}}</text>
        </view>
        <view class="rank-badge">
          <text>{{item.game_arena?.[0]?.rank || 1000}}</text>
          <text class="unit">积分</text>
        </view>
      </view>
      
      <view wx:if="{{opponents.length === 0}}" class="empty">
        <text>暂无匹配对手</text>
      </view>
    </view>
  </view>

  <!-- 奖励预览 -->
  <view class="rewards-section">
    <text class="section-title">赛季奖励</text>
    <view class="rewards-list">
      <view class="reward-item">
        <text class="rank">前10名</text>
        <text class="prize">传说称号 + 10000金币</text>
      </view>
      <view class="reward-item">
        <text class="rank">前100名</text>
        <text class="prize">史诗称号 + 5000金币</text>
      </view>
      <view class="reward-item">
        <text class="rank">前500名</text>
        <text class="prize">稀有称号 + 2000金币</text>
      </view>
    </view>
    <button class="claim-btn" bindtap="claimRewards">领取奖励</button>
  </view>
</view>

<!--战斗遮罩-->
<view wx:if="{{battling}}" class="battle-mask">
  <view class="battle-animation">
    <image class="sword" src="/images/sword.png" mode="aspectFit" />
    <text class="text">⚔️ 战斗中 ⚔️</text>
  </view>
</view>
