/* 横屏公共样式 */

/* 隐藏导航栏 */
page {
  background: #0f0f1a;
  overflow: hidden;
}

/* 横屏容器基类 */
.landscape-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: row;
  background: #0f0f1a;
}

/* 左右分栏布局 */
.left-panel {
  flex: 1;
  position: relative;
}

.right-panel {
  width: 320rpx;
  background: rgba(26, 26, 46, 0.95);
  border-left: 1px solid rgba(255, 255, 255, 0.1);
  display: flex;
  flex-direction: column;
}

/* 卡片样式 */
.card {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 12rpx;
  padding: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
  margin-bottom: 12rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.card-title {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

.card-action {
  font-size: 22rpx;
  color: #4fc3f7;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #e91e63, #ff5722);
  color: #fff;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: bold;
  padding: 16rpx 32rpx;
}

.btn-secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #888;
  border-radius: 20rpx;
  font-size: 24rpx;
  padding: 14rpx 28rpx;
}

.btn-success {
  background: linear-gradient(135deg, #4caf50, #2e7d32);
  color: #fff;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: bold;
  padding: 16rpx 32rpx;
}

.btn-warning {
  background: linear-gradient(135deg, #ffd700, #ff8c00);
  color: #000;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: bold;
  padding: 16rpx 32rpx;
}

/* 进度条样式 */
.progress-bar {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-fill.hp {
  background: linear-gradient(90deg, #4caf50, #8bc34a);
}

.progress-fill.mp {
  background: linear-gradient(90deg, #2196f3, #03a9f4);
}

.progress-fill.exp {
  background: linear-gradient(90deg, #ffd700, #ff8c00);
}

/* 数值显示 */
.value-lg {
  font-size: 36rpx;
  color: #ffd700;
  font-weight: bold;
  text-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
}

.value-md {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
}

.value-sm {
  font-size: 22rpx;
  color: #888;
}

/* 标签样式 */
.label-primary {
  font-size: 20rpx;
  color: #4fc3f7;
  background: rgba(79, 195, 247, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.label-success {
  font-size: 20rpx;
  color: #4caf50;
  background: rgba(76, 175, 80, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.label-warning {
  font-size: 20rpx;
  color: #ffd700;
  background: rgba(255, 215, 0, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.label-danger {
  font-size: 20rpx;
  color: #f44336;
  background: rgba(244, 67, 54, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

/* 分隔线 */
.divider {
  height: 1px;
  background: rgba(255, 255, 255, 0.05);
  margin: 12rpx 0;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #666;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
}

/* 动画效果 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

.scale-in {
  animation: scaleIn 0.3s ease-out;
}

/* 发光效果 */
.glow-gold {
  box-shadow: 0 0 20rpx rgba(255, 215, 0, 0.3);
}

.glow-purple {
  box-shadow: 0 0 20rpx rgba(138, 43, 226, 0.3);
}

.glow-blue {
  box-shadow: 0 0 20rpx rgba(79, 195, 247, 0.3);
}
