/* 游戏主页面样式 */

.container {
  min-height: 100vh;
  background: #0a0a15;
}

/* Canvas容器 */
.canvas-container {
  position: relative;
  width: 100%;
  height: 70vh;
  overflow: hidden;
}

.game-canvas {
  width: 100%;
  height: 100%;
  background: radial-gradient(ellipse at center, #1a1a2e 0%, #0a0a15 100%);
}

/* 顶部UI */
.top-ui {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 24rpx;
  padding-top: calc(24rpx + env(safe-area-inset-top));
}

.card-glass {
  background: rgba(26, 26, 46, 0.8);
  backdrop-filter: blur(10px);
  border: 1rpx solid rgba(255, 215, 0, 0.2);
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-header {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffd700, #c9a96e);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.vip-badge {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  background: #ffd700;
  color: #0a0a15;
  font-size: 20rpx;
  font-weight: bold;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.user-basic {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
}

.level {
  font-size: 24rpx;
  color: #ffd700;
}

.power {
  text-align: right;
}

.power-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #ffd700;
}

.power-label {
  font-size: 22rpx;
  color: #aaaaaa;
}

/* 货币栏 */
.currency-bar {
  display: flex;
  justify-content: space-around;
}

.currency-item {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  background: rgba(255, 215, 0, 0.1);
  border-radius: 30rpx;
}

.currency-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.currency-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #ffd700;
}

/* 底部UI */
.bottom-ui {
  position: absolute;
  bottom: 24rpx;
  left: 24rpx;
  right: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.quality-selector {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.quality-label {
  font-size: 24rpx;
  color: #aaaaaa;
}

.quality-btn {
  font-size: 24rpx;
  color: #666666;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.1);
}

.quality-btn.active {
  color: #ffd700;
  background: rgba(255, 215, 0, 0.2);
}

.particle-count {
  font-size: 24rpx;
  color: #666666;
}

/* 功能按钮 */
.action-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding: 24rpx;
  background: #0f0f1a;
}

.action-btn {
  flex: 1;
  min-width: 45%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 32rpx 24rpx;
  background: linear-gradient(135deg, #1a1a2e, #252540);
  border: 2rpx solid rgba(255, 215, 0, 0.3);
  border-radius: 24rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #ffd700, #c9a96e);
}

.action-btn.primary .btn-icon,
.action-btn.primary .btn-text {
  color: #0a0a15;
}

.btn-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.btn-text {
  font-size: 28rpx;
  color: #ffffff;
}

/* 弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-height: 80vh;
  background: #1a1a2e;
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 215, 0, 0.3);
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #ffd700;
}

.modal-close {
  font-size: 40rpx;
  color: #aaaaaa;
  padding: 8rpx;
}

/* 充值弹窗 */
.recharge-packages {
  max-height: 60vh;
  padding: 24rpx;
}

.package-item {
  position: relative;
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: #252540;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
}

.package-item.recommended {
  border-color: #10b981;
}

.package-item.hot {
  border-color: #ef4444;
}

.package-item.best-value {
  border-color: #ffd700;
  background: linear-gradient(135deg, #252540, #1a1a2e);
}

.package-badge {
  position: absolute;
  top: -10rpx;
  right: 24rpx;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
  background: #ffd700;
  color: #0a0a15;
}

.package-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.package-bonus {
  font-size: 24rpx;
  color: #10b981;
  margin-bottom: 12rpx;
}

.package-items {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.item-text {
  font-size: 26rpx;
  color: #aaaaaa;
}

.package-price {
  display: flex;
  align-items: baseline;
  justify-content: flex-end;
}

.price-symbol {
  font-size: 28rpx;
  color: #ffd700;
}

.price-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffd700;
}

/* GM面板 */
.gm-modal {
  max-height: 70vh;
}

.gm-section {
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.gm-section-title {
  display: block;
  font-size: 28rpx;
  color: #aaaaaa;
  margin-bottom: 16rpx;
}

.gm-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.gm-btn {
  flex: 1;
  min-width: 30%;
  padding: 20rpx;
  background: #252540;
  border: 2rpx solid rgba(255, 215, 0, 0.3);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #ffd700;
}

.gm-btn.danger {
  border-color: #ef4444;
  color: #ef4444;
}

.gm-data {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.gm-data text {
  font-size: 26rpx;
  color: #aaaaaa;
  padding: 12rpx 20rpx;
  background: #252540;
  border-radius: 12rpx;
}
