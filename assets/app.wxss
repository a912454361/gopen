/**
 * 剑破苍穹 - 全局样式
 */

/* 主题变量 */
page {
  --primary-color: #ffd700;
  --secondary-color: #c9a96e;
  --background-dark: #0f0f1a;
  --background-card: #1a1a2e;
  --background-light: #252540;
  --text-primary: #ffffff;
  --text-secondary: #aaaaaa;
  --text-muted: #666666;
  --danger-color: #ef4444;
  --success-color: #10b981;
  --warning-color: #f59e0b;
  
  background-color: var(--background-dark);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 容器 */
.container {
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background: var(--background-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(255, 215, 0, 0.2);
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

/* 按钮 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
  color: var(--background-dark);
}

.btn-secondary {
  background: var(--background-light);
  color: var(--text-primary);
  border: 2rpx solid var(--primary-color);
}

.btn-danger {
  background: var(--danger-color);
  color: var(--text-primary);
}

.btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* 选择按钮 */
.choice-btn {
  display: flex;
  align-items: center;
  padding: 32rpx;
  margin-bottom: 20rpx;
  background: var(--background-card);
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.choice-btn:active {
  border-color: var(--primary-color);
  background: var(--background-light);
}

.choice-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--primary-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.choice-icon text {
  color: var(--background-dark);
  font-size: 32rpx;
  font-weight: bold;
}

.choice-text {
  flex: 1;
  font-size: 32rpx;
  color: var(--text-primary);
}

/* 标题 */
.title-lg {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.title-md {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.title-sm {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

/* 文本 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-muted {
  color: var(--text-muted);
}

.text-gold {
  color: var(--primary-color);
}

/* 标签 */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.badge-primary {
  background: rgba(255, 215, 0, 0.2);
  color: var(--primary-color);
}

.badge-success {
  background: rgba(16, 185, 129, 0.2);
  color: var(--success-color);
}

.badge-danger {
  background: rgba(239, 68, 68, 0.2);
  color: var(--danger-color);
}

/* 进度条 */
.progress-bar {
  height: 12rpx;
  background: var(--background-light);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--secondary-color));
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 属性面板 */
.stat-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.stat-label {
  width: 120rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.stat-bar {
  flex: 1;
  height: 16rpx;
  background: var(--background-light);
  border-radius: 8rpx;
  overflow: hidden;
  margin: 0 16rpx;
}

.stat-value {
  width: 60rpx;
  font-size: 26rpx;
  color: var(--primary-color);
  text-align: right;
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.fade-in {
  animation: fadeIn 0.5s ease forwards;
}

.pulse {
  animation: pulse 2s ease infinite;
}

/* 战斗界面 */
.battle-container {
  padding: 40rpx;
}

.hp-bar {
  height: 24rpx;
  background: var(--background-light);
  border-radius: 12rpx;
  overflow: hidden;
  margin-top: 16rpx;
}

.hp-fill {
  height: 100%;
  transition: width 0.5s ease;
}

.hp-fill.player {
  background: linear-gradient(90deg, #10b981, #34d399);
}

.hp-fill.enemy {
  background: linear-gradient(90deg, #ef4444, #f87171);
}

/* 技能按钮 */
.skill-btn {
  flex: 1;
  padding: 24rpx 16rpx;
  background: var(--background-light);
  border-radius: 16rpx;
  text-align: center;
  margin: 8rpx;
  border: 2rpx solid transparent;
}

.skill-btn:active {
  border-color: var(--primary-color);
}

.skill-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.skill-name {
  font-size: 24rpx;
  color: var(--text-primary);
}

.skill-cost {
  font-size: 20rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* 结局页面 */
.ending-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 40rpx;
}

.ending-badge {
  padding: 24rpx 64rpx;
  border-radius: 48rpx;
  margin-bottom: 48rpx;
}

.ending-badge.good {
  background: linear-gradient(135deg, #10b981, #34d399);
}

.ending-badge.normal {
  background: linear-gradient(135deg, #f59e0b, #fbbf24);
}

.ending-badge.bad {
  background: linear-gradient(135deg, #ef4444, #f87171);
}

/* 成就列表 */
.achievement-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: var(--background-card);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.achievement-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}

.achievement-info {
  flex: 1;
}

.achievement-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.achievement-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.achievement-locked {
  opacity: 0.5;
  filter: grayscale(100%);
}
