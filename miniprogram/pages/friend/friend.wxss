/* 好友页面样式 */
.friend-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0a1a2e 0%, #0f0f1a 100%);
}

/* Tab切换 */
.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.05);
  padding: 20rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #888;
  border-radius: 10rpx;
}

.tab-item.active {
  color: #4fc3f7;
  background: rgba(79, 195, 247, 0.1);
  font-weight: bold;
}

/* 添加好友按钮 */
.add-btn {
  margin: 20rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #4fc3f7, #29b6f6);
  border-radius: 16rpx;
  text-align: center;
}

.add-btn text {
  font-size: 30rpx;
  color: #fff;
  font-weight: bold;
}

/* 在线计数 */
.online-count {
  padding: 0 20rpx 20rpx;
  font-size: 26rpx;
  color: #888;
}

/* 好友列表 */
.friends-list {
  padding: 0 20rpx;
}

.friend-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border: 1px solid rgba(255, 255, 255, 0.05);
}

.avatar-section {
  position: relative;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2px solid #4fc3f7;
}

.online-dot {
  position: absolute;
  bottom: 2rpx;
  right: 2rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #666;
  border: 2px solid #0f0f1a;
}

.online-dot.online {
  background: #4caf50;
}

.info-section {
  flex: 1;
  margin-left: 20rpx;
}

.info-section .name {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
  display: block;
}

.info-section .level {
  font-size: 24rpx;
  color: #888;
  display: block;
  margin-top: 6rpx;
}

.intimacy {
  margin-top: 8rpx;
}

.intimacy text {
  font-size: 22rpx;
  color: #e91e63;
  background: rgba(233, 30, 99, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.action-section {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.action-btn {
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  background: rgba(79, 195, 247, 0.2);
  color: #4fc3f7;
  border-radius: 10rpx;
  border: none;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 100rpx;
  color: #666;
  font-size: 28rpx;
}

/* 好友申请 */
.requests-list {
  padding: 20rpx;
}

.request-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.03);
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.request-item .avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
}

.request-item .name {
  flex: 1;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #fff;
}

.accept-btn, .reject-btn {
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  border-radius: 10rpx;
  margin-left: 10rpx;
}

.accept-btn {
  background: #4caf50;
  color: #fff;
}

.reject-btn {
  background: rgba(244, 67, 54, 0.2);
  color: #f44336;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: #1a1a2e;
  border-radius: 20rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  color: #fff;
  text-align: center;
  display: block;
  margin-bottom: 30rpx;
}

.input {
  width: 100%;
  background: rgba(255, 255, 255, 0.05);
  border: 1px solid rgba(79, 195, 247, 0.3);
  border-radius: 16rpx;
  padding: 24rpx;
  color: #fff;
  font-size: 30rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.modal-btns button {
  flex: 1;
  padding: 20rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
}

.cancel {
  background: rgba(255, 255, 255, 0.1);
  color: #888;
}

.confirm {
  background: linear-gradient(135deg, #4fc3f7, #29b6f6);
  color: #fff;
}
